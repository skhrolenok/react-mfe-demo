# Environment variables for Module Federation
# Copy this file to .env and update with your production URLs

# Development (default)
VITE_MFE_USER_URL=http://localhost:3001
VITE_MFE_TICKET_URL=http://localhost:3002

# Production on Render.com (uncomment and update with your actual Render URLs)
# Each MFE is a separate service on Render, all use PORT=10000 internally
# VITE_MFE_USER_URL=https://your-mfe-user-management.onrender.com
# VITE_MFE_TICKET_URL=https://your-mfe-ticketing.onrender.com

# Render.com automatically sets PORT=10000 for all web services
# No need to set PORT variable on Render
